{
  "i18n": true,
  "type": "tabs",
  "items": {
    "mainTab": {
      "type": "panel",
      "label": "Main settings",
      "items": {
        "localIp": {
          "type": "text",
          "label": "Local IP / Hostname of Touchline controller",
          "help": "Example: 192.168.1.20 or http://192.168.1.20:8899"
        },
        "apiPort": {
          "type": "number",
          "label": "Touchline API port",
          "min": 1,
          "max": 65535,
          "default": 80
        },
        "requestTimeout": {
          "type": "number",
          "label": "HTTP timeout (ms)",
          "min": 1000,
          "max": 60000,
          "default": 5000
        },
        "protocol": {
          "type": "select",
          "label": "Protocol",
          "options": [
            { "label": "HTTP", "value": "http" },
            { "label": "HTTPS", "value": "https" }
          ]
        },
        "pollInterval": {
          "type": "number",
          "label": "Polling interval (seconds)",
          "min": 10,
          "max": 3600,
          "default": 60
        },
        "username": {
          "type": "text",
          "label": "Username (optional)"
        },
        "password": {
          "type": "password",
          "label": "Password (optional)"
        },
        "token": {
          "type": "password",
          "label": "Bearer token (optional)"
        },
        "customEndpoints": {
          "type": "text",
          "label": "Additional legacy API paths",
          "help": "Separated by comma, semicolon or newline, e.g. /json/temperatures"
        }
      }
    },
    "bridgeTab": {
      "type": "panel",
      "label": "Web bridge",
      "items": {
        "enableWebServer": {
          "type": "checkbox",
          "label": "Enable local bridge webserver"
        },
        "webPort": {
          "type": "number",
          "label": "Webserver port",
          "min": 1024,
          "max": 65535,
          "default": 8099
        }
      }
    }
  }
}
